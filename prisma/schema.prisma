generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ────────────────────────────────────────────

enum Role {
  ADMIN
  READER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  emailVerified DateTime?
  name      String?
  image     String?
  role      Role     @default(READER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  comments         Comment[]
  likes            Like[]
  commentLikes     CommentLike[]
  bookLikes        BookLike[]
  bookComments     BookComment[]
  bookCommentLikes BookCommentLike[]
  audioLikes        AudioLike[]
  audioComments     AudioComment[]
  audioCommentLikes AudioCommentLike[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@unique([token])
  @@map("verification_tokens")
}

// ─── Genres ──────────────────────────────────────────────────

model Genre {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?

  poems Poem[]

  @@map("genres")
}

// ─── Tags ────────────────────────────────────────────────────

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  poems PoemTag[]

  @@map("tags")
}

// ─── Poems ───────────────────────────────────────────────────

enum PoemLanguage {
  EN
  HI
  MR
}

model Poem {
  id          String   @id @default(cuid())
  language    PoemLanguage @default(EN)
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  font        String?

  genreId String?
  genre   Genre?  @relation(fields: [genreId], references: [id])

  tags     PoemTag[]
  comments Comment[]
  likes    Like[]

  @@index([genreId])
  @@index([language])
  @@index([published, publishedAt(sort: Desc)])
  @@map("poems")
}

model PoemTag {
  poemId String
  tagId  String

  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([poemId, tagId])
  @@map("poem_tags")
}

// ─── Books ───────────────────────────────────────────────────

enum BookStatus {
  COMING_SOON
  AVAILABLE
  ARCHIVED
}

model Book {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  coverImage   String?
  coverData    String?
  coverMime    String?
  price             Decimal? @db.Decimal(10, 2)
  discountedPrice   Decimal? @db.Decimal(10, 2)
  shippingCharge    Decimal  @default(40) @db.Decimal(10, 2)
  purchaseUrl  String?
  featured     Boolean    @default(false)
  status       BookStatus @default(COMING_SOON)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  likes    BookLike[]
  comments BookComment[]
  orders   BookOrder[]

  @@map("books")
}

model BookLike {
  bookId    String
  userId    String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bookId, userId])
  @@index([userId])
  @@map("book_likes")
}

model BookComment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes BookCommentLike[]

  @@index([bookId, status])
  @@index([userId])
  @@map("book_comments")
}

model BookCommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment BookComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("book_comment_likes")
}

// ─── Comments ────────────────────────────────────────────────

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Comment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  poemId String
  poem   Poem   @relation(fields: [poemId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes CommentLike[]

  @@index([poemId, status])
  @@index([userId])
  @@map("comments")
}

model CommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("comment_likes")
}

// ─── Likes ───────────────────────────────────────────────────

model Like {
  poemId    String
  userId    String
  createdAt DateTime @default(now())

  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([poemId, userId])
  @@index([userId])
  @@map("likes")
}

// ─── Book Orders ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  REJECTED
}

model BookOrder {
  id               String      @id @default(cuid())
  orderNumber      String?     @unique
  idempotencyKey   String?     @unique
  name             String
  email            String
  phone            String
  address          String
  city             String
  state            String
  pincode          String
  copies           Int         @default(1)
  shippingAmount   Decimal     @default(40) @db.Decimal(10, 2)
  totalAmount      Decimal     @db.Decimal(10, 2)
  paymentData      String?
  paymentMime      String?
  paymentUrl       String?
  status           OrderStatus @default(PENDING)
  adminNote        String?
  trackingProvider String?
  trackingNumber   String?
  trackingUrl      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([status])
  @@map("book_orders")
}

// ─── Newsletter ──────────────────────────────────────────────

model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  verified      Boolean   @default(false)
  verifyToken   String?   @unique
  subscribedAt  DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("subscribers")
}

model Campaign {
  id        String   @id @default(cuid())
  subject   String
  body      String
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@map("campaigns")
}

model Audio {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  audioUrl    String
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    AudioComment[]
  likes       AudioLike[]

  @@map("audio")
}

model AudioLike {
  audioId   String
  userId    String
  createdAt DateTime @default(now())

  audio Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([audioId, userId])
  @@index([userId])
  @@map("audio_likes")
}

model AudioComment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  audioId String
  audio   Audio   @relation(fields: [audioId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes AudioCommentLike[]

  @@index([audioId, status])
  @@index([userId])
  @@map("audio_comments")
}

model AudioCommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment AudioComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("audio_comment_likes")
}
