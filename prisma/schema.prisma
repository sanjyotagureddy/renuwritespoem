generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ────────────────────────────────────────────

enum Role {
  ADMIN
  READER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  emailVerified DateTime?
  name      String?
  image     String?
  role      Role     @default(READER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flaggedAt DateTime?
  disabledAt DateTime?
  moderationNote String?
  passwordHash   String?

  accounts         Account[]
  sessions         Session[]
  comments         Comment[]
  likes            Like[]
  commentLikes     CommentLike[]
  bookLikes        BookLike[]
  bookComments     BookComment[]
  bookCommentLikes BookCommentLike[]
  audioLikes        AudioLike[]
  audioComments     AudioComment[]
  audioCommentLikes AudioCommentLike[]
  invites           Invite[]
  savedPoems        SavedPoem[]
  savedBooks        SavedBook[]
  poemViews         ReaderPoemView[]
  bookViews         ReaderBookView[]
  signUpSource      String?

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@unique([token])
  @@map("verification_tokens")
}

// ─── Genres ──────────────────────────────────────────────────

model Genre {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?

  poems Poem[]

  @@map("genres")
}

// ─── Tags ────────────────────────────────────────────────────

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  poems PoemTag[]

  @@map("tags")
}

// ─── Poems ───────────────────────────────────────────────────

enum PoemLanguage {
  EN
  HI
  MR
}

model Poem {
  id          String   @id @default(cuid())
  language    PoemLanguage @default(EN)
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  font        String?
  views       Int      @default(0)

  genreId String?
  genre   Genre?  @relation(fields: [genreId], references: [id])

  tags     PoemTag[]
  comments Comment[]
  likes    Like[]
  invites  Invite[]
  saves    SavedPoem[]
  readerViews ReaderPoemView[]

  @@index([genreId])
  @@index([language])
  @@index([published, publishedAt(sort: Desc)])
  @@map("poems")
}

model PoemTag {
  poemId String
  tagId  String

  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([poemId, tagId])
  @@map("poem_tags")
}

model SavedPoem {
  userId    String
  poemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@id([userId, poemId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_poems")
}

model ReaderPoemView {
  userId   String
  poemId   String
  viewedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@id([userId, poemId])
  @@index([userId, viewedAt(sort: Desc)])
  @@map("reader_poem_views")
}

// ─── Books ───────────────────────────────────────────────────

enum BookStatus {
  COMING_SOON
  AVAILABLE
  ARCHIVED
}

model Book {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  coverImage   String?
  coverData    String?
  coverMime    String?
  price             Decimal? @db.Decimal(10, 2)
  discountedPrice   Decimal? @db.Decimal(10, 2)
  shippingCharge    Decimal  @default(40) @db.Decimal(10, 2)
  purchaseUrl  String?
  featured     Boolean    @default(false)
  status       BookStatus @default(COMING_SOON)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  views        Int        @default(0)

  likes    BookLike[]
  comments BookComment[]
  orders   BookOrder[]
  saves    SavedBook[]
  readerViews ReaderBookView[]

  @@map("books")
}

model BookLike {
  bookId    String
  userId    String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bookId, userId])
  @@index([userId])
  @@map("book_likes")
}

model SavedBook {
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([userId, bookId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_books")
}

model ReaderBookView {
  userId   String
  bookId   String
  viewedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([userId, bookId])
  @@index([userId, viewedAt(sort: Desc)])
  @@map("reader_book_views")
}

model BookComment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes BookCommentLike[]

  @@index([bookId, status])
  @@index([userId])
  @@map("book_comments")
}

model BookCommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment BookComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("book_comment_likes")
}

// ─── Comments ────────────────────────────────────────────────

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Comment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  poemId String
  poem   Poem   @relation(fields: [poemId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes CommentLike[]

  @@index([poemId, status])
  @@index([userId])
  @@map("comments")
}

model CommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("comment_likes")
}

// ─── Likes ───────────────────────────────────────────────────

model Like {
  poemId    String
  userId    String
  createdAt DateTime @default(now())

  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([poemId, userId])
  @@index([userId])
  @@map("likes")
}

// ─── Book Orders ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  REJECTED
}

model BookOrder {
  id               String      @id @default(cuid())
  orderNumber      String?     @unique
  idempotencyKey   String?     @unique
  name             String
  email            String
  phone            String
  address          String
  city             String
  state            String
  pincode          String
  copies           Int         @default(1)
  shippingAmount   Decimal     @default(40) @db.Decimal(10, 2)
  totalAmount      Decimal     @db.Decimal(10, 2)
  paymentData      String?
  paymentMime      String?
  paymentUrl       String?
  status           OrderStatus @default(PENDING)
  adminNote        String?
  trackingProvider String?
  trackingNumber   String?
  trackingUrl      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([status])
  @@map("book_orders")
}

// ─── Newsletter ──────────────────────────────────────────────

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  verified       Boolean   @default(false)
  verifyToken    String?   @unique
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  // Preference fields
  prefPoems      Boolean   @default(true)
  prefBooks      Boolean   @default(true)
  prefAudio      Boolean   @default(true)

  @@map("subscribers")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Campaign {
  id          String             @id @default(cuid())
  subject     String
  body        String             @db.Text
  status      CampaignStatus     @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  sentCount   Int                @default(0)
  failedCount Int                @default(0)
  
  deliveries  CampaignDelivery[]

  @@map("campaigns")
}

model CampaignDelivery {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String   // "SUCCESS" | "FAILED"
  error      String?
  sentAt     DateTime @default(now())
  openedAt   DateTime?
  openCount  Int      @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clicks   CampaignClick[]

  @@index([campaignId])
  @@index([email])
  @@map("campaign_deliveries")
}

model CampaignClick {
  id         String   @id @default(cuid())
  deliveryId String
  url        String   @db.Text
  clickedAt  DateTime @default(now())

  delivery   CampaignDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("campaign_clicks")
}

model Audio {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  audioUrl    String
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  views       Int       @default(0)

  comments    AudioComment[]
  likes       AudioLike[]

  @@map("audio")
}

model AudioLike {
  audioId   String
  userId    String
  createdAt DateTime @default(now())

  audio Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([audioId, userId])
  @@index([userId])
  @@map("audio_likes")
}

model AudioComment {
  id        String        @id @default(cuid())
  body      String
  edited    Boolean       @default(false)
  status    CommentStatus @default(APPROVED)
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  audioId String
  audio   Audio   @relation(fields: [audioId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes AudioCommentLike[]

  @@index([audioId, status])
  @@index([userId])
  @@map("audio_comments")
}

model AudioCommentLike {
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment AudioComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("audio_comment_likes")
}

// ─── Contact Messages ─────────────────────────────────────────

model ContactMessage {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String
  subject     String
  message     String
  repliedAt   DateTime?
  repliedNote String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("contact_messages")
}

// ─── Invites ──────────────────────────────────────────────────

model Invite {
  id            String    @id @default(cuid())
  inviterUserId String
  inviteeName   String
  inviteeEmail  String
  poemId        String?
  personalNote  String?
  sentAt        DateTime  @default(now())
  clickedAt     DateTime?
  signedUpAt    DateTime?

  inviter User  @relation(fields: [inviterUserId], references: [id], onDelete: Cascade)
  poem    Poem? @relation(fields: [poemId], references: [id], onDelete: SetNull)

  @@index([inviterUserId])
  @@index([inviteeEmail])
  @@map("invites")
}

model UnsubscribedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("unsubscribed_emails")
}

model AttributionLog {
  id        String   @id @default(cuid())
  source    String   // e.g. 'whatsapp', 'invite', 'ig-story', 'twitter', 'facebook', 'copy-link', etc.
  path      String   // the URL path clicked (e.g. '/poems/whispers-of-the-wind')
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@map("attribution_logs")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model AuthorProfile {
  id              String   @id @default(cuid())
  whyIWrite       String?  @db.Text
  writingJourney  String?  @db.Text
  inspiration     String?  @db.Text
  awards          String?  @db.Text
  publications    String?  @db.Text
  interviews      String?  @db.Text
  behindTheScenes String?  @db.Text
  writingDesk     String?  @db.Text
  updatedAt       DateTime @updatedAt

  gallery         AuthorGalleryImage[]

  @@map("author_profile")
}

model AuthorGalleryImage {
  id        String   @id @default(cuid())
  url       String?
  fileData  String?  @db.Text
  fileMime  String?
  width     Int      @default(0)
  height    Int      @default(0)
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())

  profileId String
  profile   AuthorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("author_gallery_images")
}

